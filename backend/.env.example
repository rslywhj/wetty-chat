# Copy to .env and set your database URL.
# DATABASE_URL is read by the app and by Diesel CLI (e.g. diesel migration run).
DATABASE_URL=postgres://user:password@localhost/wetty_chat

# AWS / S3 Compatible
S3_BUCKET_NAME=wetty-chat-local-dev
AWS_REGION=us-west-2
# S3_ENDPOINT_URL=https://<namespace>.compat.objectstorage.<region>.oraclecloud.com
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# VAPID keys
# Generate with `npx web-push generate-vapid-keys`
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# JWT auth signing key
# Generate once with `openssl rand -base64 32` and keep it stable across restarts.
JWT_SIGNING_KEY_BASE64=

# Optional CORS allowlist, comma-separated. Leave unset to disable CORS.
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# Optional NodeID, default 0
FERRET_NODE_ID=

# DISCUZ
AUTH_METHOD=Discuz
DISCUZ_COOKIE_PREFIX=o2L2_2132
DISCUZ_AUTHKEY=myauthkey
DISCUZ_AVATAR_PUBLIC_URL=  # Public base URL for avatar images (e.g. https://example.com)
DISCUZ_AVATAR_PATH=        # Absolute filesystem path to Discuz avatar directory
