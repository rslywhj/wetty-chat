# Copy to .env before starting the backend.
# DATABASE_URL is read by the app and by Diesel CLI (for example `diesel migration run`).
DATABASE_URL=postgres://wetty_chat:change_me@127.0.0.1:5432/wetty_chat

# Local auth mode: use X-User-Id headers instead of Discuz cookies.
# This matches the web frontend dev setup.
AUTH_METHOD=UIDHeader

# Required at startup. Generate once and keep stable across restarts:
#   openssl rand -base64 32
JWT_SIGNING_KEY_BASE64=

# Required at startup for Web Push support:
#   npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dev@example.com

# Required by the backend for attachment storage.
# For local development you can point these at any S3-compatible provider or rely on
# your existing AWS credential chain.
S3_BUCKET_NAME=wetty-chat-local-dev
AWS_REGION=us-west-2
# S3_ENDPOINT_URL=http://127.0.0.1:9000
# AWS_ACCESS_KEY_ID=rustfsadmin
# AWS_SECRET_ACCESS_KEY=rustfsadmin
# ATTACHMENTS_PREFIX=attachments
# S3_BASE_URL=http://127.0.0.1:9000/wetty-chat-local-dev

# Optional, comma-separated. Leave unset to disable CORS.
# CORS_ALLOWED_ORIGINS=http://localhost:5173

# Optional listen addresses.
# APP_ADDR=0.0.0.0:3000
# METRICS_ADDR=0.0.0.0:3001

# Optional node id, defaults to 0.
# NODE_ID=0

# Discuz-only settings. Keep these commented out for normal local development.
# AUTH_METHOD=Discuz
# DISCUZ_COOKIE_PREFIX=o2L2_2132
# DISCUZ_AUTHKEY=myauthkey
# DISCUZ_AVATAR_PUBLIC_URL=https://example.com
# DISCUZ_AVATAR_PATH=/absolute/path/to/discuz/uc_server/data/avatar
